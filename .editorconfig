root = true

[*]
indent_style = tab
indent_size = 8
tab_width = 8
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 8

[*.bat]
end_of_line = crlf

[*.ps1]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,css,scss}]
indent_style = tab
indent_size = 4
