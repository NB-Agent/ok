# OK environment variables for Docker deployment
# Copy to .env and fill in your keys

# At least one provider is required. Set the default provider.
OK_DEFAULT_PROVIDER=deepseek

# DeepSeek API key
DEEPSEEK_API_KEY=

# OpenAI API key (optional fallback)
OPENAI_API_KEY=

# Anthropic API key (optional fallback)
ANTHROPIC_API_KEY=

# OK config path (mounted as volume)
OK_CONFIG=/home/ok/ok.toml

# Server settings
OK_PORT=8080
OK_HOST=0.0.0.0
